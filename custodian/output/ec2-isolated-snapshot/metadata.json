{
  "policy": {
    "name": "ec2-isolated-snapshot",
    "resource": "ec2",
    "description": "Status=isolated \ud0dc\uadf8\uac00 \ub2ec\ub9b0 EC2 \uc778\uc2a4\ud134\uc2a4\ub97c \uac10\uc9c0\ud558\uba74\nEBS \ubcfc\ub968 \uc2a4\ub0c5\uc0f7\uc744 \uc790\ub3d9\uc73c\ub85c \uc0dd\uc131\ud574 \ud3ec\ub80c\uc2dd \uc99d\uac70\ub97c \ubcf4\uc874\ud55c\ub2e4.\n",
    "mode": {
      "type": "cloudtrail",
      "role": "arn:aws:iam::160884802838:role/EC2CustodianRole",
      "events": [
        {
          "source": "ec2.amazonaws.com",
          "event": "CreateTags",
          "ids": "requestParameters.resourcesSet.items[].resourceId"
        }
      ],
      "tags": {
        "custodian-info": "mode=cloudtrail:version=0.9.49"
      }
    },
    "filters": [
      {
        "type": "value",
        "key": "Tags[?Key=='Status'].Value | [0]",
        "value": "isolated",
        "op": "eq"
      }
    ],
    "actions": [
      {
        "type": "snapshot",
        "copy-tags": [
          "Name",
          "Status",
          "IsolatedBy"
        ]
      },
      {
        "type": "tag",
        "tags": {
          "SnapshotStatus": "completed",
          "ForensicsBy": "custodian-ec2-forensics"
        }
      }
    ]
  },
